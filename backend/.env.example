# Database Configuration
DATABASE_URL=sqlite:///./comet_hunter.db

# Utools API Configuration
UTOOLS_API_KEY=your_utools_api_key_here
UTOOLS_BASE_URL=https://twitter.good6.top/api/base/apitools
TARGET_USER_ID=1260183271930904577

# Twitter OAuth 2.0 Configuration (Required for OAuth flow)
TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here
TWITTER_CALLBACK_URL=http://localhost:3000

# Server Configuration
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# Email Configuration (Resend)
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=onboarding@resend.dev

# Monitoring Configuration
MONITORING_INTERVAL=300